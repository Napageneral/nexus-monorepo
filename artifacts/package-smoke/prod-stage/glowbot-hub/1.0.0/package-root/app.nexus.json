{
  "id": "glowbot-hub",
  "version": "1.0.0",
  "displayName": "GlowBot Hub",
  "description": "GlowBot product control plane service",
  "hosting": {
    "required_server_class": "compliant",
    "deployment_class": "product_control_plane"
  },
  "services": [
    {
      "id": "hub",
      "command": "bin/glowbot-hub",
      "healthCheck": "/health",
      "env": {
        "NEX_APP_DATA_DIR": "{{dataDir}}",
        "NEX_SERVICE_PORT": "{{port}}"
      }
    }
  ],
  "methods": {
    "glowbotHub.managedProfiles.list": {
      "description": "List GlowBot-managed profiles",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "includeArchived": {
            "type": "boolean"
          }
        }
      }
    },
    "glowbotHub.managedProfiles.get": {
      "description": "Get a managed profile",
      "action": "read",
      "params": {
        "type": "object",
        "required": [
          "managedProfileId"
        ],
        "properties": {
          "managedProfileId": {
            "type": "string"
          }
        }
      }
    },
    "glowbotHub.managedProfiles.create": {
      "description": "Create a managed profile",
      "action": "write",
      "params": {
        "type": "object"
      }
    },
    "glowbotHub.managedProfiles.update": {
      "description": "Update a managed profile",
      "action": "write",
      "params": {
        "type": "object",
        "required": [
          "managedProfileId"
        ],
        "properties": {
          "managedProfileId": {
            "type": "string"
          }
        }
      }
    },
    "glowbotHub.managedProfiles.archive": {
      "description": "Archive a managed profile",
      "action": "write",
      "params": {
        "type": "object",
        "required": [
          "managedProfileId"
        ],
        "properties": {
          "managedProfileId": {
            "type": "string"
          }
        }
      }
    },
    "glowbotHub.diagnostics.summary": {
      "description": "Get GlowBot hub diagnostics summary",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "glowbotHub.audit.list": {
      "description": "List recent GlowBot hub audit events",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "limit": {
            "type": "number"
          },
          "kind": {
            "type": "string"
          }
        }
      }
    },
    "glowbotHub.clinics.list": {
      "description": "List clinic participation summaries",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "glowbotHub.clinics.get": {
      "description": "Get a clinic participation summary",
      "action": "read",
      "params": {
        "type": "object",
        "required": [
          "clinicId"
        ],
        "properties": {
          "clinicId": {
            "type": "string"
          }
        }
      }
    },
    "glowbotHub.productFlags.list": {
      "description": "List GlowBot product flags",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "glowbotHub.productFlags.update": {
      "description": "Update GlowBot product flags",
      "action": "write",
      "params": {
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {},
          "description": {
            "type": "string"
          }
        }
      }
    },
    "glowbotHub.benchmarks.publishSnapshot": {
      "description": "Publish a benchmark-safe clinic snapshot",
      "action": "write",
      "params": {
        "type": "object"
      }
    },
    "glowbotHub.benchmarks.query": {
      "description": "Query peer benchmark records",
      "action": "read",
      "params": {
        "type": "object"
      }
    },
    "glowbotHub.benchmarks.networkHealth": {
      "description": "Get benchmark network health",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "glowbotHub.benchmarks.seed.publish": {
      "description": "Publish a benchmark seed dataset",
      "action": "write",
      "params": {
        "type": "object"
      }
    },
    "glowbotHub.benchmarks.seed.list": {
      "description": "List benchmark seed datasets",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "profileKey": {
            "type": "string"
          },
          "periodKind": {
            "type": "string"
          }
        }
      }
    },
    "glowbotHub.cohorts.list": {
      "description": "List benchmark cohorts",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {}
      }
    },
    "glowbotHub.cohorts.update": {
      "description": "Replace benchmark cohorts",
      "action": "write",
      "params": {
        "type": "object",
        "required": [
          "cohorts"
        ],
        "properties": {
          "cohorts": {
            "type": "array"
          }
        }
      }
    },
    "glowbotHub.clinicProfiles.resolve": {
      "description": "Resolve a canonical clinic benchmark profile",
      "action": "read",
      "params": {
        "type": "object",
        "required": [
          "clinicProfile"
        ],
        "properties": {
          "clinicProfile": {
            "type": "object"
          }
        }
      }
    }
  },
  "requires": {
    "nex": ">=0.9.0"
  },
  "skill": "./SKILL.md"
}
