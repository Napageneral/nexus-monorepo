{
  "name": "@nexus-project/nexus-adapter-whatsapp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nexus WhatsApp external adapter",
  "main": "dist/index.js",
  "bin": {
    "nexus-adapter-whatsapp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "sdk:generate": "pnpm --dir ../../nex exec tsx scripts/sdk/generate-adapter-sdk-ts.ts nexus-adapter-whatsapp",
    "sdk:build": "tsc -p sdk/nexus-adapter-whatsapp-sdk-ts/tsconfig.json"
  },
  "dependencies": {
    "@nexus-project/adapter-sdk-ts": "file:../nexus-adapter-sdks/nexus-adapter-sdk-ts",
    "@whiskeysockets/baileys": "7.0.0-rc.9"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.5"
  }
}
