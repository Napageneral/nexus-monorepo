{
  "platform": "discord",
  "name": "discord-adapter",
  "version": "0.1.0",
  "operations": [
    "adapter.info",
    "adapter.monitor.start",
    "adapter.setup.start",
    "delivery.send",
    "delivery.stream",
    "adapter.health",
    "adapter.accounts.list"
  ],
  "credential_service": "discord",
  "multi_account": true,
  "auth": {
    "methods": [
      {
        "type": "api_key",
        "label": "Enter Bot Token",
        "icon": "key",
        "service": "discord",
        "fields": [
          {
            "name": "bot_token",
            "label": "Bot Token",
            "type": "secret",
            "required": true
          }
        ]
      },
      {
        "type": "custom_flow",
        "label": "Run Custom Setup",
        "icon": "settings",
        "service": "discord",
        "fields": [
          {
            "name": "confirm",
            "label": "I completed prerequisite setup",
            "type": "select",
            "required": true,
            "options": [
              { "label": "Yes", "value": "yes" },
              { "label": "Not yet", "value": "no" }
            ]
          }
        ]
      }
    ]
  },
  "platform_capabilities": {
    "text_limit": 2000,
    "caption_limit": 2000,
    "supports_markdown": true,
    "markdown_flavor": "discord",
    "supports_tables": false,
    "supports_code_blocks": true,
    "supports_embeds": true,
    "supports_threads": true,
    "supports_reactions": true,
    "supports_polls": false,
    "supports_buttons": false,
    "supports_edit": true,
    "supports_delete": true,
    "supports_media": true,
    "supports_voice_notes": false,
    "supports_streaming_edit": true
  }
}
