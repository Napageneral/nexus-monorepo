{
  "name": "@nexus-project/nexus-frontdoor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hosted frontdoor scaffold for per-tenant Nexus runtimes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "sdk:generate:ts": "node --import tsx scripts/sdk/generate-frontdoor-sdk-ts.ts",
    "sdk:build:ts": "pnpm sdk:generate:ts && tsc -p ../../artifacts/sdk/ts/platform/frontdoor-sdk-ts/tsconfig.json",
    "sdk:generate:go": "node --import tsx scripts/sdk/generate-frontdoor-sdk-go.ts",
    "sdk:build:go": "pnpm sdk:generate:go && (cd ../../artifacts/sdk/go/platform/frontdoor-sdk-go && go test ./...)",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "smoke:provisioner": "node ./scripts/provisioner-smoke.mjs",
    "smoke:launch": "node ./scripts/frontdoor-launch-smoke.mjs",
    "smoke:runtime-rpc": "node ./scripts/frontdoor-runtime-rpc.mjs",
    "smoke:proof:jira-adapter": "node ./scripts/frontdoor-jira-adapter-proof.mjs",
    "smoke:proof:slack-adapter": "node ./scripts/frontdoor-slack-adapter-proof.mjs",
    "smoke:proof:runtime-health": "node ./scripts/frontdoor-fresh-server-runtime-health-proof.mjs",
    "smoke:one-server-multi-app": "node ./scripts/frontdoor-one-server-multi-app-smoke.mjs",
    "smoke:package-lifecycle": "node ./scripts/frontdoor-package-lifecycle-smoke.mjs",
    "smoke:fresh-server-package-lifecycle": "node ./scripts/frontdoor-fresh-server-package-lifecycle-smoke.mjs",
    "smoke:fresh-server-adapter-cleanroom": "node ./scripts/frontdoor-fresh-server-adapter-cleanroom-smoke.mjs",
    "smoke:fresh-server-one-server-multi-app": "node ./scripts/frontdoor-fresh-server-one-server-multi-app-smoke.mjs",
    "smoke:docker:fresh-server-package-lifecycle": "bash ./scripts/frontdoor-cleanroom-docker-executor.sh node ./scripts/frontdoor-fresh-server-package-lifecycle-smoke.mjs",
    "smoke:docker:fresh-server-adapter-cleanroom": "bash ./scripts/frontdoor-cleanroom-docker-executor.sh node ./scripts/frontdoor-fresh-server-adapter-cleanroom-smoke.mjs",
    "smoke:docker:fresh-server-one-server-multi-app": "bash ./scripts/frontdoor-cleanroom-docker-executor.sh node ./scripts/frontdoor-fresh-server-one-server-multi-app-smoke.mjs",
    "smoke:capture:fresh-server-multi-app": "bash ./scripts/capture-frontdoor-fresh-server-multi-app-smoke.sh",
    "smoke:capture:fresh-server-adapter-cleanroom": "bash ./scripts/capture-frontdoor-fresh-server-adapter-cleanroom.sh",
    "smoke:local:sandbox-runtime-health-pilot": "pnpm exec tsx ./scripts/frontdoor-local-sandbox-runtime-health-pilot.ts",
    "smoke:local:sandbox-package-lifecycle-pilot": "pnpm exec tsx ./scripts/frontdoor-local-sandbox-package-lifecycle-pilot.ts",
    "smoke:local:sandbox-jira-adapter-pilot": "pnpm exec tsx ./scripts/frontdoor-local-sandbox-jira-adapter-pilot.ts",
    "smoke:local:sandbox-slack-adapter-pilot": "pnpm exec tsx ./scripts/frontdoor-local-sandbox-slack-adapter-pilot.ts",
    "smoke:deploy": "pnpm smoke:provisioner && pnpm smoke:launch",
    "publish:adapter-release": "tsx ./scripts/publish-adapter-release.ts",
    "migrate:product-mappings:dry-run": "node ./scripts/backfill-product-mappings.mjs",
    "migrate:product-mappings": "node ./scripts/backfill-product-mappings.mjs --apply",
    "password:hash": "tsx src/password-hash.ts",
    "demo-stack:start": "bash ./scripts/demo-stack-start.sh",
    "demo-stack:stop": "bash ./scripts/demo-stack-stop.sh",
    "demo-stack:status": "bash ./scripts/demo-stack-status.sh"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.1011.0",
    "http-proxy": "^1.18.1",
    "openid-client": "^6.8.1",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^24.3.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "ajv": "^8.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18",
    "ws": "^8.18.3"
  }
}
