{
  "version": 1,
  "profiles": {
    "anthropic:claude-cli": {
      "type": "external_cli",
      "provider": "anthropic",
      "cli": "claude-code",
      "metadata": {
        "ttl_ms": "900000",
        "keychain_service": "Claude Code-credentials",
        "file_fallback": "~/.claude/.credentials.json"
      }
    },
    "openai-codex:codex-cli": {
      "type": "external_cli",
      "provider": "openai-codex",
      "cli": "codex",
      "metadata": {
        "ttl_ms": "900000",
        "keychain_service": "Codex Auth",
        "file_fallback": "$CODEX_HOME/auth.json"
      }
    },
    "qwen-portal:qwen-cli": {
      "type": "external_cli",
      "provider": "qwen-portal",
      "cli": "qwen",
      "metadata": {
        "ttl_ms": "900000",
        "file_fallback": "~/.qwen/oauth_creds.json"
      }
    }
  }
}
