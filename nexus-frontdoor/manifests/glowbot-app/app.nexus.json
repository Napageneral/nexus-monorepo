{
  "id": "glowbot",
  "version": "1.0.0",
  "displayName": "GlowBot",
  "description": "AI-powered growth intelligence for healthcare practices",
  "handler": "methods/index.ts",
  "ui": {
    "root": "dist",
    "entryPath": "/app/glowbot/",
    "spa": true
  },
  "methods": {
    "glowbot.overview": {
      "description": "Get high-level metrics overview for the practice",
      "handler": "methods/overview.ts",
      "params": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string",
            "enum": ["7d", "30d", "90d"],
            "default": "30d"
          }
        }
      },
      "access": "authenticated"
    },
    "glowbot.funnel": {
      "description": "Get conversion funnel metrics",
      "handler": "methods/funnel.ts",
      "params": {
        "type": "object",
        "properties": {
          "period": {
            "type": "string",
            "enum": ["7d", "30d", "90d"],
            "default": "30d"
          }
        }
      },
      "access": "authenticated"
    },
    "glowbot.modeling": {
      "description": "Get predictive modeling insights",
      "handler": "methods/modeling.ts",
      "params": {
        "type": "object",
        "properties": {
          "model": {
            "type": "string",
            "description": "Model type to use for predictions"
          },
          "window": {
            "type": "string",
            "enum": ["3m", "6m", "12m"],
            "default": "6m"
          }
        },
        "required": ["model"]
      },
      "access": "authenticated"
    },
    "glowbot.agents": {
      "description": "Get list of available AI agents",
      "handler": "methods/agents.ts",
      "access": "authenticated"
    },
    "glowbot.agents.recommendations": {
      "description": "Get AI-powered recommendations from agents",
      "handler": "methods/agents-recommendations.ts",
      "params": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string",
            "description": "Filter recommendations by category"
          },
          "limit": {
            "type": "number",
            "description": "Maximum number of recommendations to return",
            "default": 10
          }
        }
      },
      "access": "authenticated"
    },
    "glowbot.integrations": {
      "description": "List all configured integrations and their status",
      "handler": "methods/integrations.ts",
      "access": "authenticated"
    },
    "glowbot.integrations.connect.oauth.start": {
      "description": "Start OAuth flow for an adapter",
      "handler": "methods/integrations-connect-oauth-start.ts",
      "params": {
        "type": "object",
        "properties": {
          "adapterId": {
            "type": "string",
            "description": "ID of the adapter to connect"
          }
        },
        "required": ["adapterId"]
      },
      "access": "authenticated"
    },
    "glowbot.integrations.connect.apikey": {
      "description": "Connect an adapter using API key authentication",
      "handler": "methods/integrations-connect-apikey.ts",
      "params": {
        "type": "object",
        "properties": {
          "adapterId": {
            "type": "string",
            "description": "ID of the adapter to connect"
          },
          "fields": {
            "type": "object",
            "description": "Authentication fields (API keys, tokens, etc.)"
          }
        },
        "required": ["adapterId", "fields"]
      },
      "access": "authenticated"
    },
    "glowbot.integrations.connect.upload": {
      "description": "Connect an adapter by uploading a credentials file",
      "handler": "methods/integrations-connect-upload.ts",
      "params": {
        "type": "object",
        "properties": {
          "adapterId": {
            "type": "string",
            "description": "ID of the adapter to connect"
          },
          "file": {
            "type": "string",
            "description": "Base64-encoded file content"
          },
          "filename": {
            "type": "string",
            "description": "Original filename"
          }
        },
        "required": ["adapterId", "file", "filename"]
      },
      "access": "authenticated"
    },
    "glowbot.integrations.test": {
      "description": "Test connection to an adapter",
      "handler": "methods/integrations-test.ts",
      "params": {
        "type": "object",
        "properties": {
          "adapterId": {
            "type": "string",
            "description": "ID of the adapter to test"
          }
        },
        "required": ["adapterId"]
      },
      "access": "authenticated"
    },
    "glowbot.integrations.disconnect": {
      "description": "Disconnect an adapter and remove credentials",
      "handler": "methods/integrations-disconnect.ts",
      "params": {
        "type": "object",
        "properties": {
          "adapterId": {
            "type": "string",
            "description": "ID of the adapter to disconnect"
          }
        },
        "required": ["adapterId"]
      },
      "access": "authenticated"
    },
    "glowbot.pipeline.status": {
      "description": "Get current status of the data pipeline",
      "handler": "methods/pipeline-status.ts",
      "access": "authenticated"
    },
    "glowbot.pipeline.trigger": {
      "description": "Manually trigger a pipeline run",
      "handler": "methods/pipeline-trigger.ts",
      "access": "admin"
    }
  },
  "adapters": [
    {
      "id": "google-ads",
      "name": "Google Ads",
      "platform": "google",
      "command": "../../../adapters/nexus-adapter-gog-ads/bin/gog-ads-adapter",
      "description": "Sync advertising campaign data from Google Ads",
      "authMethods": [
        {
          "type": "oauth",
          "label": "Connect with Google"
        }
      ]
    },
    {
      "id": "google-business-profile",
      "name": "Google Business Profile",
      "platform": "google",
      "command": "../../../adapters/nexus-adapter-gog-places/bin/gog-places-adapter",
      "description": "Sync business profile and review data from Google",
      "authMethods": [
        {
          "type": "oauth",
          "label": "Connect with Google"
        }
      ]
    },
    {
      "id": "meta-ads",
      "name": "Meta Ads",
      "platform": "meta",
      "command": "../../../adapters/nexus-adapter-meta-ads/bin/meta-ads-adapter",
      "description": "Sync advertising campaign data from Meta (Facebook/Instagram)",
      "authMethods": [
        {
          "type": "oauth",
          "label": "Connect with Meta"
        }
      ]
    },
    {
      "id": "patient-now-emr",
      "name": "PatientNow EMR",
      "platform": "patientnow",
      "command": "../../../adapters/nexus-adapter-patient-now-emr/bin/patient-now-emr-adapter",
      "description": "Sync patient and appointment data from PatientNow EMR",
      "authMethods": [
        {
          "type": "apikey",
          "label": "API Key Authentication",
          "fields": [
            {
              "name": "apiKey",
              "label": "API Key",
              "type": "password",
              "required": true
            },
            {
              "name": "practiceId",
              "label": "Practice ID",
              "type": "text",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "id": "zenoti-emr",
      "name": "Zenoti EMR",
      "platform": "zenoti",
      "command": "../../../adapters/nexus-adapter-zenoti-emr/bin/zenoti-emr-adapter",
      "description": "Sync patient and appointment data from Zenoti EMR",
      "authMethods": [
        {
          "type": "apikey",
          "label": "API Key Authentication",
          "fields": [
            {
              "name": "apiKey",
              "label": "API Key",
              "type": "password",
              "required": true
            },
            {
              "name": "centerId",
              "label": "Center ID",
              "type": "text",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "id": "apple-maps",
      "name": "Apple Maps",
      "platform": "apple",
      "command": "../../../adapters/nexus-adapter-apple-maps/bin/apple-maps-adapter",
      "description": "Sync business profile data from Apple Maps",
      "authMethods": [
        {
          "type": "upload",
          "label": "Upload Credentials File",
          "fields": [
            {
              "name": "file",
              "label": "JSON Credentials File",
              "type": "file",
              "required": true
            }
          ]
        }
      ]
    }
  ],
  "hooks": {
    "onInstall": "hooks/install.ts",
    "onActivate": "hooks/activate.ts",
    "onDeactivate": "hooks/deactivate.ts",
    "onUpgrade": "hooks/upgrade.ts",
    "onUninstall": "hooks/uninstall.ts"
  },
  "product": {
    "icon": "assets/icon.svg",
    "color": "#6366f1",
    "tagline": "AI-powered growth intelligence",
    "plans": [
      {
        "id": "free",
        "name": "Free",
        "tier": "free",
        "entitlements": {
          "adapters_max": "2",
          "pipeline_runs_per_day": "1",
          "retention_days": "30",
          "hub_access": "false",
          "custom_models": "false"
        }
      },
      {
        "id": "starter",
        "name": "Starter",
        "tier": "starter",
        "price": {
          "amount": 99,
          "currency": "USD",
          "interval": "month"
        },
        "entitlements": {
          "adapters_max": "5",
          "pipeline_runs_per_day": "4",
          "retention_days": "90",
          "hub_access": "true",
          "custom_models": "false"
        }
      },
      {
        "id": "professional",
        "name": "Professional",
        "tier": "professional",
        "price": {
          "amount": 299,
          "currency": "USD",
          "interval": "month"
        },
        "entitlements": {
          "adapters_max": "10",
          "pipeline_runs_per_day": "12",
          "retention_days": "365",
          "hub_access": "true",
          "custom_models": "true"
        }
      },
      {
        "id": "enterprise",
        "name": "Enterprise",
        "tier": "enterprise",
        "entitlements": {
          "adapters_max": "unlimited",
          "pipeline_runs_per_day": "unlimited",
          "retention_days": "unlimited",
          "hub_access": "true",
          "custom_models": "true"
        }
      }
    ]
  },
  "entitlements": {
    "adapters_max": {
      "description": "Maximum number of adapters that can be configured",
      "type": "number",
      "default": "2"
    },
    "pipeline_runs_per_day": {
      "description": "Maximum number of pipeline runs allowed per day",
      "type": "number",
      "default": "1"
    },
    "retention_days": {
      "description": "Number of days to retain historical data",
      "type": "number",
      "default": "30"
    },
    "hub_access": {
      "description": "Access to GlowBot Hub for publishing and sharing insights",
      "type": "boolean",
      "default": "false"
    },
    "custom_models": {
      "description": "Ability to create and deploy custom AI models",
      "type": "boolean",
      "default": "false"
    }
  }
}
