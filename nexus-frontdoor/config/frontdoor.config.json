{
  "host": "127.0.0.1",
  "port": 4789,
  "baseUrl": "http://127.0.0.1:4789",
  "session": {
    "cookieName": "nexus_fd_session",
    "ttlSeconds": 604800,
    "storePath": "./state/frontdoor-sessions.db"
  },
  "runtimeToken": {
    "issuer": "https://app.example.com",
    "audience": "control-plane",
    "secret": "change-me-frontdoor-runtime-token-secret",
    "activeKid": "v1",
    "keys": {
      "v1": "change-me-frontdoor-runtime-token-secret"
    },
    "ttlSeconds": 600,
    "refreshTtlSeconds": 2592000
  },
  "security": {
    "rateLimits": {
      "loginAttempts": { "windowSeconds": 60, "maxAttempts": 30, "blockSeconds": 60 },
      "loginFailures": { "windowSeconds": 900, "maxAttempts": 8, "blockSeconds": 900 },
      "tokenEndpoints": { "windowSeconds": 60, "maxAttempts": 120, "blockSeconds": 60 },
      "proxyRequests": { "windowSeconds": 60, "maxAttempts": 1000, "blockSeconds": 30 }
    }
  },
  "tenants": {
    "tenant-dev": {
      "runtimeUrl": "http://127.0.0.1:18789",
      "runtimePublicBaseUrl": "http://127.0.0.1:18789"
    }
  },
  "users": [
    {
      "id": "user-owner",
      "username": "owner",
      "passwordHash": "scrypt-sha256-v1$Q2Pk_UGb_MWMHj_iNKt5mw$9LMyZ85W_i5G5yK-q22uow7_jL3ule5gyrXxlXE3C0g",
      "tenantId": "tenant-dev",
      "entityId": "entity-owner",
      "displayName": "Owner",
      "email": "owner@example.com",
      "roles": ["operator"],
      "scopes": ["*"]
    }
  ],
  "oidc": {
    "enabled": false,
    "providers": {
      "google": {
        "clientId": "change-me",
        "clientSecret": "change-me",
        "issuer": "https://accounts.google.com",
        "jwksUrl": "https://www.googleapis.com/oauth2/v3/certs",
        "authorizeUrl": "https://accounts.google.com/o/oauth2/v2/auth",
        "tokenUrl": "https://oauth2.googleapis.com/token",
        "userInfoUrl": "https://openidconnect.googleapis.com/v1/userinfo",
        "scope": "openid profile email",
        "redirectUri": "http://127.0.0.1:4789/api/auth/oidc/callback/google"
      }
    },
    "mappings": [
      {
        "provider": "google",
        "tenantId": "tenant-dev",
        "entityIdTemplate": "oidc:{sub}",
        "roles": ["member"],
        "scopes": ["chat.send", "chat.history"],
        "match": {
          "emailDomain": "example.com"
        }
      }
    ]
  },
  "autoProvision": {
    "enabled": false,
    "storePath": "./state/frontdoor-autoprovision.db",
    "providers": ["google"],
    "tenantIdPrefix": "tenant",
    "defaultRoles": ["operator"],
    "defaultScopes": ["operator.admin"],
    "command": "node /Users/tyler/nexus/home/projects/nexus/nexus-frontdoor/scripts/provision-tenant-local.mjs",
    "commandTimeoutMs": 120000
  },
  "billing": {
    "provider": "none",
    "checkoutSuccessUrl": "https://frontdoor.example.com/billing/success",
    "checkoutCancelUrl": "https://frontdoor.example.com/billing/cancel",
    "webhookSecret": "change-me-frontdoor-billing-webhook-secret",
    "stripeSecretKey": "change-me-stripe-secret-key",
    "stripeApiBaseUrl": "https://api.stripe.com",
    "stripePriceIdsByPlan": {
      "starter": "price_starter",
      "pro": "price_pro",
      "business": "price_business"
    }
  }
}
