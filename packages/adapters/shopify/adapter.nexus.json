{
  "id": "shopify",
  "version": "0.2.3",
  "displayName": "Shopify",
  "description": "Canonical Shopify adapter package for Nex with GraphQL-backed provider methods and additive projection.",
  "platform": "shopify",
  "command": "./bin/shopify-adapter",
  "skill": "./SKILL.md",
  "methods": {
    "shopify.source.project-captured-page": {
      "description": "Project one exact previously captured Shopify orders page into canonical Nex records without a Shopify request or cursor advancement.",
      "action": "read",
      "connection_required": true,
      "mutates_remote": false,
      "params": {
        "type": "object",
        "properties": {
          "family": {
            "type": "string",
            "enum": [
              "orders.delta"
            ]
          },
          "observation_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-zA-Z0-9._:-]+$"
          },
          "provider_response_json": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8388608
          },
          "provider_response_gzip_base64": {
            "type": "string",
            "minLength": 1,
            "maxLength": 950000
          },
          "provider_response_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "request_url": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "request_since": {
            "type": "string"
          },
          "window_through": {
            "type": "string"
          },
          "record_offset": {
            "type": "integer",
            "minimum": 0,
            "maximum": 1000000
          },
          "record_limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500
          }
        },
        "required": [
          "family",
          "observation_id",
          "provider_response_sha256",
          "request_url",
          "request_since",
          "window_through"
        ],
        "additionalProperties": false
      },
      "response": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "enum": [
              1
            ]
          },
          "family": {
            "type": "string",
            "enum": [
              "orders.delta"
            ]
          },
          "connection_id": {
            "type": "string"
          },
          "shop_domain": {
            "type": "string"
          },
          "observation_id": {
            "type": "string"
          },
          "provider_response_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "source_rows": {
            "type": "integer",
            "minimum": 0
          },
          "record_offset": {
            "type": "integer",
            "minimum": 0
          },
          "record_limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500
          },
          "total_records": {
            "type": "integer",
            "minimum": 0
          },
          "next_record_offset": {
            "type": "integer",
            "minimum": 0
          },
          "complete": {
            "type": "boolean"
          },
          "records": {
            "type": "array",
            "maxItems": 500,
            "items": {
              "type": "object"
            }
          },
          "provider_calls": {
            "type": "integer",
            "enum": [
              0
            ]
          },
          "provider_write_authority": {
            "type": "boolean",
            "enum": [
              false
            ]
          },
          "cursor_advanced": {
            "type": "boolean",
            "enum": [
              false
            ]
          }
        },
        "required": [
          "version",
          "family",
          "connection_id",
          "shop_domain",
          "observation_id",
          "provider_response_sha256",
          "source_rows",
          "record_offset",
          "record_limit",
          "total_records",
          "next_record_offset",
          "complete",
          "records",
          "provider_calls",
          "provider_write_authority",
          "cursor_advanced"
        ],
        "additionalProperties": false
      }
    },
    "shopify.source.capture": {
      "description": "Capture one bounded page for one Shopify source family without advancing its durable cursor.",
      "action": "read",
      "connection_required": true,
      "mutates_remote": false,
      "params": {
        "type": "object",
        "properties": {
          "family": {
            "type": "string",
            "enum": [
              "orders.delta",
              "customers.delta",
              "inventory.hot",
              "inventory.reconcile",
              "fulfillment.delta",
              "discounts.delta",
              "finance.transactions",
              "disputes.delta",
              "products.delta",
              "catalog.delta",
              "marketing.delta",
              "payouts.delta"
            ]
          }
        },
        "required": [
          "family"
        ],
        "additionalProperties": false
      },
      "response": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "enum": [
              1
            ]
          },
          "family": {
            "type": "string",
            "enum": [
              "orders.delta",
              "customers.delta",
              "inventory.hot",
              "inventory.reconcile",
              "fulfillment.delta",
              "discounts.delta",
              "finance.transactions",
              "disputes.delta",
              "products.delta",
              "catalog.delta",
              "marketing.delta",
              "payouts.delta"
            ]
          },
          "connection_id": {
            "type": "string"
          },
          "shop_domain": {
            "type": "string"
          },
          "capture_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$"
          },
          "request_since": {
            "type": "string"
          },
          "window_through": {
            "type": "string"
          },
          "page_cursor": {
            "type": "string"
          },
          "next_cursor": {
            "type": "string"
          },
          "complete": {
            "type": "boolean"
          },
          "records": {
            "type": "array",
            "maxItems": 500,
            "items": {
              "type": "object"
            }
          }
        },
        "required": [
          "version",
          "family",
          "connection_id",
          "shop_domain",
          "capture_id",
          "request_since",
          "window_through",
          "complete",
          "records"
        ],
        "additionalProperties": false
      }
    },
    "shopify.source.commit": {
      "description": "Advance one Shopify source-family cursor only after every captured Nex record was durably ingested.",
      "action": "write",
      "connection_required": true,
      "mutates_remote": false,
      "params": {
        "type": "object",
        "properties": {
          "family": {
            "type": "string",
            "enum": [
              "orders.delta",
              "customers.delta",
              "inventory.hot",
              "inventory.reconcile",
              "fulfillment.delta",
              "discounts.delta",
              "finance.transactions",
              "disputes.delta",
              "products.delta",
              "catalog.delta",
              "marketing.delta",
              "payouts.delta"
            ]
          },
          "capture_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$"
          }
        },
        "required": [
          "family",
          "capture_id"
        ],
        "additionalProperties": false
      },
      "response": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "enum": [
              1
            ]
          },
          "family": {
            "type": "string",
            "enum": [
              "orders.delta",
              "customers.delta",
              "inventory.hot",
              "inventory.reconcile",
              "fulfillment.delta",
              "discounts.delta",
              "finance.transactions",
              "disputes.delta",
              "products.delta",
              "catalog.delta",
              "marketing.delta",
              "payouts.delta"
            ]
          },
          "capture_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$"
          },
          "cursor_iso": {
            "type": "string"
          },
          "page_cursor": {
            "type": "string"
          },
          "window_through": {
            "type": "string"
          },
          "complete": {
            "type": "boolean"
          }
        },
        "required": [
          "version",
          "family",
          "capture_id",
          "cursor_iso",
          "complete"
        ],
        "additionalProperties": false
      }
    },
    "shopify.source.abort": {
      "description": "Release one exact Shopify source capture after a downstream Nex ingest failure without advancing its cursor.",
      "action": "write",
      "connection_required": true,
      "mutates_remote": false,
      "params": {
        "type": "object",
        "properties": {
          "family": {
            "type": "string",
            "enum": [
              "orders.delta",
              "customers.delta",
              "inventory.hot",
              "inventory.reconcile",
              "fulfillment.delta",
              "discounts.delta",
              "finance.transactions",
              "disputes.delta",
              "products.delta",
              "catalog.delta",
              "marketing.delta",
              "payouts.delta"
            ]
          },
          "capture_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$"
          }
        },
        "required": [
          "family",
          "capture_id"
        ],
        "additionalProperties": false
      },
      "response": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "enum": [
              1
            ]
          },
          "family": {
            "type": "string",
            "enum": [
              "orders.delta",
              "customers.delta",
              "inventory.hot",
              "inventory.reconcile",
              "fulfillment.delta",
              "discounts.delta",
              "finance.transactions",
              "disputes.delta",
              "products.delta",
              "catalog.delta",
              "marketing.delta",
              "payouts.delta"
            ]
          },
          "capture_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{32}$"
          },
          "aborted": {
            "type": "boolean",
            "enum": [
              true
            ]
          }
        },
        "required": [
          "version",
          "family",
          "capture_id",
          "aborted"
        ],
        "additionalProperties": false
      }
    },
    "records.backfill.stage": {
      "description": "Stage and export an exact fixed-window Shopify customer/order snapshot for Nex historical import.",
      "action": "read",
      "connection_required": true,
      "mutates_remote": false,
      "params": {
        "type": "object",
        "properties": {
          "since": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "stage_dir": {
            "type": "string"
          }
        },
        "required": [
          "since",
          "to",
          "stage_dir"
        ],
        "additionalProperties": false
      },
      "response": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "enum": [
              2
            ]
          },
          "format": {
            "type": "string",
            "enum": [
              "jsonl_files_sha256"
            ]
          },
          "stage_dir": {
            "type": "string"
          },
          "manifest_path": {
            "type": "string"
          },
          "manifest_file_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "connection_id": {
            "type": "string"
          },
          "shop_domain": {
            "type": "string"
          },
          "since": {
            "type": "string"
          },
          "through": {
            "type": "string"
          },
          "source_manifest_path": {
            "type": "string"
          },
          "source_manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "totals": {
            "type": "object",
            "properties": {
              "records": {
                "type": "integer"
              }
            },
            "required": [
              "records"
            ],
            "additionalProperties": false
          },
          "chunks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "records": {
                  "type": "integer"
                },
                "first_record_id": {
                  "type": "string"
                },
                "last_record_id": {
                  "type": "string"
                },
                "first_timestamp_ms": {
                  "type": "integer"
                },
                "last_timestamp_ms": {
                  "type": "integer"
                },
                "byte_count": {
                  "type": "integer"
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "source_page_path": {
                  "type": "string"
                },
                "source_page_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                }
              },
              "required": [
                "path",
                "records",
                "first_record_id",
                "last_record_id",
                "first_timestamp_ms",
                "last_timestamp_ms",
                "byte_count",
                "sha256",
                "source_page_path",
                "source_page_sha256"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "version",
          "format",
          "stage_dir",
          "manifest_path",
          "manifest_file_sha256",
          "connection_id",
          "shop_domain",
          "since",
          "through",
          "source_manifest_path",
          "source_manifest_sha256",
          "chunks",
          "totals"
        ],
        "additionalProperties": false
      }
    }
  },
  "methodCatalog": {
    "source": "graphql",
    "document": "api/graphql.catalog.json",
    "namespace": "shopify"
  }
}
