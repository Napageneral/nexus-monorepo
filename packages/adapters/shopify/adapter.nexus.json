{
  "id": "shopify",
  "version": "0.1.0",
  "displayName": "Shopify",
  "description": "Canonical Shopify adapter package for Nex with GraphQL-backed provider methods and additive projection.",
  "platform": "shopify",
  "command": "./bin/shopify-adapter",
  "skill": "./SKILL.md",
  "methods": {
    "records.backfill.stage": {
      "description": "Stage and export an exact fixed-window Shopify customer/order snapshot for Nex historical import.",
      "action": "read",
      "connection_required": true,
      "mutates_remote": false,
      "params": {
        "type": "object",
        "properties": {
          "since": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "stage_dir": {
            "type": "string"
          }
        },
        "required": [
          "since",
          "to",
          "stage_dir"
        ],
        "additionalProperties": false
      },
      "response": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "enum": [
              2
            ]
          },
          "format": {
            "type": "string",
            "enum": [
              "jsonl_files_sha256"
            ]
          },
          "stage_dir": {
            "type": "string"
          },
          "manifest_path": {
            "type": "string"
          },
          "manifest_file_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "connection_id": {
            "type": "string"
          },
          "shop_domain": {
            "type": "string"
          },
          "since": {
            "type": "string"
          },
          "through": {
            "type": "string"
          },
          "source_manifest_path": {
            "type": "string"
          },
          "source_manifest_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "totals": {
            "type": "object",
            "properties": {
              "records": {
                "type": "integer"
              }
            },
            "required": [
              "records"
            ],
            "additionalProperties": false
          },
          "chunks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string"
                },
                "records": {
                  "type": "integer"
                },
                "first_record_id": {
                  "type": "string"
                },
                "last_record_id": {
                  "type": "string"
                },
                "first_timestamp_ms": {
                  "type": "integer"
                },
                "last_timestamp_ms": {
                  "type": "integer"
                },
                "byte_count": {
                  "type": "integer"
                },
                "sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                },
                "source_page_path": {
                  "type": "string"
                },
                "source_page_sha256": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{64}$"
                }
              },
              "required": [
                "path",
                "records",
                "first_record_id",
                "last_record_id",
                "first_timestamp_ms",
                "last_timestamp_ms",
                "byte_count",
                "sha256",
                "source_page_path",
                "source_page_sha256"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "version",
          "format",
          "stage_dir",
          "manifest_path",
          "manifest_file_sha256",
          "connection_id",
          "shop_domain",
          "since",
          "through",
          "source_manifest_path",
          "source_manifest_sha256",
          "chunks",
          "totals"
        ],
        "additionalProperties": false
      }
    }
  },
  "methodCatalog": {
    "source": "graphql",
    "document": "api/graphql.catalog.json",
    "namespace": "shopify"
  }
}
