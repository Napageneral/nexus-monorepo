{
  "name": "@nexus-project/linkedin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nexus LinkedIn external adapter",
  "main": "dist/index.js",
  "bin": {
    "linkedin": "dist/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && pnpm exec esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nexus-project/adapter-sdk-ts": "file:../nexus-adapter-sdks/nexus-adapter-sdk-ts"
  },
  "devDependencies": {
    "@types/node": "24.10.13",
    "esbuild": "0.27.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
