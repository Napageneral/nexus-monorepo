{
  "id": "moonsleep-commerce",
  "version": "0.3.2",
  "displayName": "MoonSleep Commerce",
  "description": "Project exact Shopify records into MoonSleep identity and typed commerce state through public Nex operations.",
  "skill": "./SKILL.md",
  "handler": "./methods/index.ts",
  "hooks": {
    "onInstall": "./hooks/install.ts",
    "onActivate": "./hooks/activate.ts",
    "onDeactivate": "./hooks/deactivate.ts",
    "onUpgrade": "./hooks/upgrade.ts",
    "onUninstall": "./hooks/uninstall.ts"
  },
  "hosting": {
    "required_server_class": "standard",
    "deployment_class": "customer_server"
  },
  "product": {
    "tagline": "Exact provider evidence into durable customer and commerce state",
    "accentColor": "#0f766e",
    "visibility": "customer",
    "plans": [
      {
        "id": "moonsleep-commerce-internal",
        "displayName": "MoonSleep Commerce Internal",
        "priceMonthly": 0,
        "isDefault": true
      }
    ]
  },
  "methods": {
    "moonsleep-commerce.healthcheck": {
      "description": "Report the installed MoonSleep commerce projector contract.",
      "action": "read",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {}
      },
      "response": {
        "type": "object"
      }
    },
    "moonsleep-commerce.shopify-source.seed-identities": {
      "description": "Replay-safely seed distinct Shopify store and integration identities and ground the local receiver to MoonSleep Ops through public Nex identity operations.",
      "action": "write",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "shop_domain": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.myshopify\\.com$",
            "maxLength": 255
          },
          "connection_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$",
            "maxLength": 128
          }
        },
        "required": ["shop_domain", "connection_id"],
        "additionalProperties": false
      },
      "response": {
        "type": "object"
      }
    },
    "moonsleep-commerce.shopify-source.trigger": {
      "description": "Queue one exact Shopify source family immediately through its durable Nex job without enabling the recurring schedule.",
      "action": "write",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "family": {
            "type": "string",
            "enum": [
              "orders.delta",
              "customers.delta",
              "inventory.hot",
              "inventory.reconcile",
              "fulfillment.delta",
              "discounts.delta",
              "finance.transactions",
              "disputes.delta",
              "products.delta",
              "catalog.delta",
              "marketing.delta",
              "payouts.delta"
            ]
          },
          "connection_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-zA-Z0-9._-]+$"
          },
          "request_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128,
            "pattern": "^[a-zA-Z0-9._:-]+$"
          }
        },
        "required": [
          "family",
          "connection_id",
          "request_id"
        ],
        "additionalProperties": false
      },
      "response": {
        "type": "object"
      }
    },
    "moonsleep-commerce.shopify-source.configure-schedules": {
      "description": "Plan or apply the exact connection binding and independently enabled Shopify source schedules without making a Shopify provider request.",
      "action": "write",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["plan", "apply"]
          },
          "connection_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$",
            "maxLength": 128
          },
          "enabled_families": {
            "type": "array",
            "uniqueItems": true,
            "maxItems": 12,
            "items": {
              "type": "string",
              "enum": [
                "orders.delta",
                "customers.delta",
                "inventory.hot",
                "inventory.reconcile",
                "fulfillment.delta",
                "discounts.delta",
                "finance.transactions",
                "disputes.delta",
                "products.delta",
                "catalog.delta",
                "marketing.delta",
                "payouts.delta"
              ]
            }
          },
          "expected_plan_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "confirmation": {
            "type": "string",
            "enum": ["CONFIGURE_MOONSLEEP_SHOPIFY_SOURCE_SCHEDULES"]
          }
        },
        "required": ["mode", "connection_id", "enabled_families"],
        "additionalProperties": false
      },
      "response": {
        "type": "object"
      }
    },
    "moonsleep-commerce.shopify-customers.project-cohort": {
      "description": "Project an explicit bounded cohort of committed Shopify customer records into Nex identity using replay-safe public operations.",
      "action": "write",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "record_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          }
        },
        "required": ["record_ids"],
        "additionalProperties": false
      },
      "response": {
        "type": "object"
      }
    },
    "moonsleep-commerce.shopify-customers.project-backfill": {
      "description": "Project one explicit bounded batch of committed Shopify customer records into Nex identity and return deterministic replay counters and hashes.",
      "action": "write",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "record_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 250,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          },
          "record_set_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "required": ["record_ids", "record_set_sha256"],
        "additionalProperties": false
      },
      "response": {
        "type": "object"
      }
    },
    "moonsleep-commerce.shopify-customers.inspect-backfill": {
      "description": "Read, validate, and return the exact sorted committed Shopify customer record IDs and their hash through public records.list without projecting identities.",
      "action": "read",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "shop_domain": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.myshopify\\.com$",
            "maxLength": 255
          },
          "connection_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$",
            "maxLength": 128
          }
        },
        "required": ["shop_domain", "connection_id"],
        "additionalProperties": false
      },
      "response": {
        "type": "object"
      }
    },
    "moonsleep-commerce.shopify-commerce.inspect-backfill": {
      "description": "Read and validate the exact sorted committed Shopify order and line-item record IDs without calling Shopify or projecting commerce state.",
      "action": "read",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "shop_domain": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?\\.myshopify\\.com$",
            "maxLength": 255
          },
          "connection_id": {
            "type": "string",
            "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,126}[a-z0-9])?$",
            "maxLength": 128
          }
        },
        "required": ["shop_domain", "connection_id"],
        "additionalProperties": false
      },
      "response": {
        "type": "object"
      }
    },
    "moonsleep-commerce.shopify-commerce.project-backfill": {
      "description": "Project one explicit resource-bounded batch of committed Shopify order and line-item records through public Nex commerce operations.",
      "action": "write",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "record_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 512
            }
          },
          "record_set_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "required": ["record_ids", "record_set_sha256"],
        "additionalProperties": false
      },
      "response": {
        "type": "object"
      }
    }
  }
}
