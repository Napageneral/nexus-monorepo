{
  "id": "moonsleep-partner-desk",
  "version": "0.1.0",
  "displayName": "MoonSleep Partner Desk",
  "description": "Track reviewed supplier and partner open loops over immutable provider-native communications.",
  "skill": "./SKILL.md",
  "handler": "./methods/index.ts",
  "hooks": {
    "onInstall": "./hooks/install.ts",
    "onActivate": "./hooks/activate.ts",
    "onDeactivate": "./hooks/deactivate.ts",
    "onUpgrade": "./hooks/upgrade.ts",
    "onUninstall": "./hooks/uninstall.ts"
  },
  "hosting": {
    "required_server_class": "standard",
    "deployment_class": "customer_server"
  },
  "product": {
    "tagline": "Every supplier question tracked to evidence-backed closure",
    "accentColor": "#8a5a31",
    "visibility": "customer",
    "plans": [
      {
        "id": "moonsleep-partner-desk-internal",
        "displayName": "MoonSleep Partner Desk Internal",
        "priceMonthly": 0,
        "isDefault": true
      }
    ]
  },
  "methods": {
    "moonsleep-partner-desk.healthcheck": {
      "description": "Report the installed Partner Desk projection and dormant work contract.",
      "action": "read",
      "access": "authenticated",
      "params": {"type": "object", "properties": {}, "additionalProperties": false},
      "response": {"type": "object"}
    },
    "moonsleep-partner-desk.alibaba.inspect-conversation": {
      "description": "Inspect and hash one complete committed Alibaba native conversation without returning message content.",
      "action": "read",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "connection_id": {"type": "string", "minLength": 1, "maxLength": 128},
          "provider_thread_id": {"type": "string", "minLength": 1, "maxLength": 512}
        },
        "required": ["connection_id", "provider_thread_id"],
        "additionalProperties": false
      },
      "response": {"type": "object"}
    },
    "moonsleep-partner-desk.project-reviewed-cohort": {
      "description": "Project a bounded reviewed cohort into native threads, independent open loops, and attention queues.",
      "action": "read",
      "access": "authenticated",
      "params": {
        "type": "object",
        "properties": {
          "record_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50,
            "uniqueItems": true,
            "items": {"type": "string", "minLength": 1, "maxLength": 512}
          },
          "identity_resolutions": {"type": "array", "maxItems": 50, "items": {"type": "object"}},
          "workspace_assertions": {"type": "array", "maxItems": 50, "items": {"type": "object"}},
          "open_loop_assertions": {"type": "array", "maxItems": 100, "items": {"type": "object"}},
          "source_coverage_assertions": {"type": "array", "maxItems": 50, "items": {"type": "object"}}
        },
        "required": [
          "record_ids",
          "identity_resolutions",
          "workspace_assertions",
          "open_loop_assertions",
          "source_coverage_assertions"
        ],
        "additionalProperties": false
      },
      "response": {"type": "object"}
    }
  }
}
