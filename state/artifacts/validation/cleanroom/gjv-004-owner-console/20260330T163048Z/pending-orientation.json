    "distinctions": [
      {
        "name": "workspace root vs workspaces",
        "detail": "The Nex workspace root is the local filesystem root. Runtime/user-facing workspaces are database-backed product nouns that can also have readable state under state/workspaces/."
      },
      {
        "name": "identity workspace vs session/work workspace",
        "detail": "Identity workspaces hold readable context for entities such as owner or assistant. Session/work workspaces hold execution-local state for active work."
      },
      {
        "name": "records vs conversations vs sessions",
        "detail": "Records are raw source events, conversations are agent-facing communication threads, and sessions are lower-level runtime execution continuity."
      },
      {
        "name": "Nex API vs Frontdoor/App/Adapter APIs",
        "detail": "The local nexus CLI projects the Nex runtime API directly. Frontdoor is a separate hosted API contract, while app and adapter APIs are discovered through runtime method catalogs plus published contracts."
      }
    ],
