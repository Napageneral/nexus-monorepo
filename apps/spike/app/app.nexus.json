{
  "id": "spike",
  "version": "1.0.0",
  "displayName": "Spike",
  "description": "AI-powered code intelligence and repository analysis",
  "ui": {
    "root": "dist",
    "entryPath": "/app/spike/",
    "spa": true
  },
  "services": [
    {
      "id": "engine",
      "command": "bin/spike-engine",
      "args": ["serve", "--port", "{{port}}"],
      "healthCheck": "/health",
      "env": {
        "NEX_APP_DATA_DIR": "{{dataDir}}",
        "NEX_SERVICE_PORT": "{{port}}"
      }
    }
  ],
  "methods": {
    "spike.ask": {
      "description": "Ask a question about code in a repository tree",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["query", "index_id"],
        "properties": {
          "query": { "type": "string", "description": "Natural language question about the code" },
          "index_id": { "type": "string", "description": "Agent index identifier" },
          "json": { "type": "boolean", "description": "Return structured JSON response" }
        }
      }
    },
    "spike.status": {
      "description": "Get engine health and status information",
      "action": "read",
      "params": { "type": "object", "properties": {} }
    },
    "spike.sync": {
      "description": "Synchronize a repository tree with remote source",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["tree_id"],
        "properties": {
          "tree_id": { "type": "string" },
          "hydrate": { "type": "boolean" },
          "repo_id": { "type": "string" },
          "remote_url": { "type": "string" },
          "ref": { "type": "string" }
        }
      }
    },
    "spike.jobs.get": {
      "description": "Get details of a specific job",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["job_id"],
        "properties": { "job_id": { "type": "string" } }
      }
    },
    "spike.jobs.list": {
      "description": "List jobs for a tree",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "tree_id": { "type": "string" },
          "status": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    "spike.repositories.get": {
      "description": "Get details of a specific repository",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["repo_id"],
        "properties": { "repo_id": { "type": "string" } }
      }
    },
    "spike.repositories.list": {
      "description": "List repositories",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "repo_id": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    "spike.repo-refs.get": {
      "description": "Get details of a repository reference",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["repo_id", "ref_name"],
        "properties": {
          "repo_id": { "type": "string" },
          "ref_name": { "type": "string" }
        }
      }
    },
    "spike.repo-refs.list": {
      "description": "List repository references",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "repo_id": { "type": "string" },
          "ref_name": { "type": "string" },
          "commit_sha": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    "spike.tree-versions.get": {
      "description": "Get details of a specific tree version",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["id"],
        "properties": { "id": { "type": "string" } }
      }
    },
    "spike.tree-versions.list": {
      "description": "List tree versions",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "tree_id": { "type": "string" },
          "repo_id": { "type": "string" },
          "ref_name": { "type": "string" },
          "commit_sha": { "type": "string" },
          "status": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    "spike.ask-requests.get": {
      "description": "Get details of a specific ask request",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["tree_id", "request_id"],
        "properties": {
          "tree_id": { "type": "string" },
          "request_id": { "type": "string" }
        }
      }
    },
    "spike.ask-requests.list": {
      "description": "List ask requests for a tree",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "tree_id": { "type": "string" },
          "status": { "type": "string" },
          "scope_key": { "type": "string" },
          "ref_name": { "type": "string" },
          "commit_sha": { "type": "string" },
          "tree_version_id": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    "spike.ask-requests.inspect": {
      "description": "Inspect detailed ask request execution data",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["tree_id", "request_id"],
        "properties": {
          "tree_id": { "type": "string" },
          "request_id": { "type": "string" }
        }
      }
    },
    "spike.ask-requests.timeline": {
      "description": "Get timeline of ask request execution",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["tree_id", "request_id"],
        "properties": {
          "tree_id": { "type": "string" },
          "request_id": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    "spike.sessions.list": {
      "description": "List sessions for a tree",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "tree_id": { "type": "string" },
          "limit": { "type": "number" }
        }
      }
    },
    "spike.sessions.resolve": {
      "description": "Resolve session data with scope",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["tree_id", "key"],
        "properties": {
          "tree_id": { "type": "string" },
          "key": { "type": "string" },
          "scope": { "type": "string" }
        }
      }
    },
    "spike.sessions.preview": {
      "description": "Preview session data without applying changes",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["tree_id", "key"],
        "properties": {
          "tree_id": { "type": "string" },
          "key": { "type": "string" }
        }
      }
    },
    "spike.sessions.patch": {
      "description": "Apply patch operations to session",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["tree_id", "key", "operations"],
        "properties": {
          "tree_id": { "type": "string" },
          "key": { "type": "string" },
          "operations": { "type": "array" }
        }
      }
    },
    "spike.sessions.reset": {
      "description": "Reset session to initial state",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["tree_id", "key"],
        "properties": {
          "tree_id": { "type": "string" },
          "key": { "type": "string" }
        }
      }
    },
    "spike.sessions.delete": {
      "description": "Delete a session",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["tree_id", "key"],
        "properties": {
          "tree_id": { "type": "string" },
          "key": { "type": "string" }
        }
      }
    },
    "spike.sessions.compact": {
      "description": "Compact session data to optimize storage",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["tree_id", "key"],
        "properties": {
          "tree_id": { "type": "string" },
          "key": { "type": "string" }
        }
      }
    },
    "spike.sessions.import": {
      "description": "Import session data from external source",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["tree_id", "key", "data"],
        "properties": {
          "tree_id": { "type": "string" },
          "key": { "type": "string" },
          "data": { "type": "object" }
        }
      }
    },
    "spike.sessions.import-chunk": {
      "description": "Import session data chunk for large imports",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["tree_id", "key", "chunk"],
        "properties": {
          "tree_id": { "type": "string" },
          "key": { "type": "string" },
          "chunk": { "type": "object" }
        }
      }
    },
    "spike.indexes.create": {
      "description": "Create a new index from a repository and ref",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["repo_url"],
        "properties": {
          "repo_url": { "type": "string", "description": "Git remote URL" },
          "ref": { "type": "string", "description": "Git ref (branch, tag, commit)" },
          "display_name": { "type": "string", "description": "Human-readable name for the index" },
          "config_id": { "type": "string", "description": "Agent config ID (default: 'default')" }
        }
      }
    },
    "spike.indexes.list": {
      "description": "List all agent indexes",
      "action": "read",
      "params": { "type": "object", "properties": {} }
    },
    "spike.indexes.get": {
      "description": "Get details for a specific index",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["index_id"],
        "properties": {
          "index_id": { "type": "string" }
        }
      }
    },
    "spike.indexes.delete": {
      "description": "Delete an index and all associated data",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["index_id"],
        "properties": {
          "index_id": { "type": "string" }
        }
      }
    },
    "spike.indexes.status": {
      "description": "Get hydration status and progress for an index",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["index_id"],
        "properties": {
          "index_id": { "type": "string" }
        }
      }
    },
    "spike.mirrors.list": {
      "description": "List all git mirrors",
      "action": "read",
      "params": { "type": "object", "properties": {} }
    },
    "spike.worktrees.list": {
      "description": "List all worktrees",
      "action": "read",
      "params": { "type": "object", "properties": {} }
    },
    "spike.github.installations.list": {
      "description": "List connected GitHub installations",
      "action": "read",
      "params": { "type": "object", "properties": {} }
    },
    "spike.github.installations.get": {
      "description": "Get a specific GitHub installation",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["installation_id"],
        "properties": {
          "installation_id": { "type": "integer" }
        }
      }
    },
    "spike.config.defaults": {
      "description": "Get default agent configuration",
      "action": "read",
      "params": { "type": "object", "properties": {} }
    },
    "spike.config.get": {
      "description": "Get agent configuration by ID",
      "action": "read",
      "params": {
        "type": "object",
        "properties": {
          "config_id": { "type": "string" }
        }
      }
    },
    "spike.config.update": {
      "description": "Update agent configuration",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["config_id"],
        "properties": {
          "config_id": { "type": "string" },
          "capacity": { "type": "integer" },
          "max_children": { "type": "integer" },
          "max_parallel": { "type": "integer" },
          "display_name": { "type": "string" }
        }
      }
    },
    "spike.connectors.github.install.start": {
      "description": "Start the managed Spike GitHub App installation flow",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["connectionProfileId"],
        "properties": {
          "connectionProfileId": { "type": "string" }
        }
      }
    },
    "spike.connectors.github.repos": {
      "description": "List GitHub repositories accessible to connector",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["installation_id"],
        "properties": {
          "installation_id": { "type": "integer" }
        }
      }
    },
    "spike.connectors.github.branches": {
      "description": "List branches for a GitHub repository",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["installation_id", "repo_id"],
        "properties": {
          "installation_id": { "type": "integer" },
          "repo_id": { "type": "string" }
        }
      }
    },
    "spike.connectors.github.commits": {
      "description": "List commits for a GitHub repository reference",
      "action": "read",
      "params": {
        "type": "object",
        "required": ["installation_id", "repo_id", "ref"],
        "properties": {
          "installation_id": { "type": "integer" },
          "repo_id": { "type": "string" },
          "ref": { "type": "string" }
        }
      }
    },
    "spike.connectors.github.remove": {
      "description": "Remove a connected GitHub installation",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["installation_id"],
        "properties": {
          "installation_id": { "type": "integer" }
        }
      }
    },
    "spike.connectors.github.setup": {
      "description": "Persist a bring-your-own GitHub App installation secret",
      "action": "write",
      "params": {
        "type": "object",
        "required": ["app_id", "installation_id", "private_key_pem"],
        "properties": {
          "app_id": { "type": "string" },
          "installation_id": { "type": "string" },
          "installation_account_login": { "type": "string" },
          "api_base_url": { "type": "string" },
          "private_key_pem": { "type": "string" }
        }
      }
    },
    "spike.github.webhook": {
      "description": "Handle GitHub webhook events",
      "action": "write",
      "access": "admin",
      "params": {
        "type": "object",
        "properties": {
          "event": { "type": "string" },
          "payload": { "type": "object" }
        }
      }
    }
  },
  "hooks": {
    "onInstall": "hooks/install.ts",
    "onActivate": "hooks/activate.ts",
    "onDeactivate": "hooks/deactivate.ts",
    "onUpgrade": "hooks/upgrade.ts",
    "onUninstall": "hooks/uninstall.ts"
  },
  "product": {
    "icon": "assets/icon.svg",
    "color": "#10b981",
    "tagline": "AI-powered code intelligence",
    "plans": [
      {
        "id": "spike-free",
        "name": "Free",
        "tier": "free",
        "entitlements": {
          "repositories_max": "3",
          "asks_per_day": "10",
          "retention_days": "30"
        }
      },
      {
        "id": "spike-pro",
        "name": "Pro",
        "tier": "professional",
        "price": {
          "amount": 49,
          "currency": "usd",
          "interval": "month"
        },
        "entitlements": {
          "repositories_max": "unlimited",
          "asks_per_day": "unlimited",
          "retention_days": "365"
        }
      }
    ]
  },
  "entitlements": {
    "repositories_max": {
      "description": "Maximum repositories",
      "type": "number",
      "default": "3"
    },
    "asks_per_day": {
      "description": "Daily ask limit",
      "type": "number",
      "default": "10"
    },
    "retention_days": {
      "description": "Data retention in days",
      "type": "number",
      "default": "30"
    }
  },
  "adapters": [
    {
      "id": "github",
      "packageId": "github",
      "displayName": "GitHub",
      "description": "Connect repositories with GitHub",
      "connectionProfiles": [
        {
          "id": "spike-managed-github-app",
          "displayName": "Connect with Spike GitHub App",
          "authMethodId": "github_app_managed",
          "scope": "app",
          "managedProfileId": "spike-github-app"
        },
        {
          "id": "bring-your-own-github-app",
          "displayName": "Use my own GitHub App",
          "authMethodId": "github_app_custom",
          "scope": "server"
        },
        {
          "id": "personal-access-token",
          "displayName": "Use a Personal Access Token",
          "authMethodId": "pat",
          "scope": "server"
        }
      ]
    }
  ],
  "requires": {
    "nex": ">=0.9.0",
    "adapters": [
      { "id": "github", "version": "^1.0.0" }
    ]
  }
}
